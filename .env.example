# =============================================================================
# Project Nexus — 환경 변수 템플릿
# 이 파일을 .env로 복사한 후 실제 값을 입력한다.
# 모든 변수는 NEXUS_ 접두사를 사용한다.
# =============================================================================

# GPU 서버 (Machine B)
NEXUS_GPU_SERVER_URL=http://192.168.22.28:8000

# Redis (단기 메모리)
NEXUS_REDIS__HOST=192.168.10.39
NEXUS_REDIS__PORT=6379
NEXUS_REDIS__PASSWORD=

# PostgreSQL (장기 메모리)
NEXUS_POSTGRESQL__HOST=192.168.10.39
NEXUS_POSTGRESQL__PORT=5432
NEXUS_POSTGRESQL__DATABASE=nexus
NEXUS_POSTGRESQL__USER=nexus
NEXUS_POSTGRESQL__PASSWORD=

# 모델
NEXUS_MODEL__PRIMARY_MODEL=gemma-4-31b-it
NEXUS_MODEL__AUXILIARY_MODEL=exaone-7.8b

# 운영
NEXUS_LOG_LEVEL=INFO
NEXUS_DEBUG=false
NEXUS_AIR_GAP_MODE=true
